{
  "name": "mysql-cdc",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mysql",
    "database.port": "3306",
    "database.user": "root",
    "database.password": "root",
    "database.server.id": "100",
    "topic.prefix": "mysql",
    "database.include.list": "app",
    "schema.history.internal.kafka.bootstrap.servers": "kafka-broker:9092",
    "schema.history.internal.kafka.topic": "_schema_history.mysql",
    "include.schema.changes": "true",
    "value.converter": "io.apicurio.registry.utils.converter.AvroConverter",
    "value.converter.apicurio.registry.url": "http://schema-registry:8080/apis/registry/v2",
    "value.converter.apicurio.registry.auto-register": "true",
    "value.converter.apicurio.registry.find-latest": "true"
  }
}
