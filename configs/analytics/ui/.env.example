# LDS Analytics UI — Environment Variables
# Copy to .env and adjust values for your setup.
#
# Nuxt auto-maps NUXT_PUBLIC_* env vars to runtimeConfig.public.*
# So NUXT_PUBLIC_API_BASE here → runtimeConfig.public.apiBase in code

# API base URL (auto-mapped to runtimeConfig.public.apiBase)
NUXT_PUBLIC_API_BASE=http://localhost:3001
