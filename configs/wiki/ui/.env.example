# LDS Wiki UI — Environment Variables
# Copy to .env and adjust values for your setup.
#
# Next.js auto-loads .env files natively. No extra setup needed.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Others (like API_URL) are server-only (used in next.config.ts).

# API base URL for the Next.js rewrites proxy (server-side only)
API_URL=http://localhost:3003
