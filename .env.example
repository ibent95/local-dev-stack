# =============================================================================
# Local Development Stack — copy to .env and adjust as needed:
#   cp .env.example .env
#
# Ordering: GLOBAL settings first, then the DEFAULT RUN-SET toggles, shared
# VERSIONS and PROJECT PATHS, and finally one block PER SERVICE (most specific).
# =============================================================================


# #############################################################################
# 1. GLOBAL
# #############################################################################
TZ=Asia/Jakarta
NETWORK_NAME=lds-network
# Registry for base-image push (./lds.sh build-bases --push). Empty/local = local only.
REGISTRY=local


# #############################################################################
# 2. DEFAULT RUN-SET — per-service on/off toggles
# -----------------------------------------------------------------------------
# These decide which services come up when you run `lds up` / `lds start` with
# NO profile args. One independent switch per profile: set to `true` to include
# it in the default run-set, `false` to leave it off. Flip a single line to turn
# a group on/off — no comma-list editing.
#
#   proxy -> edge proxy + dns       php -> php-fpm + nginx (also pulls proxy + dns)
#   phpcacheadmin -> phpCacheAdmin UI    dbgate -> DBGate UI (independent toggles)
#
# NOTE: passing explicit profiles (`lds up kafka`) ignores ALL toggles and
# starts ONLY what you asked for. If every toggle is false, `lds up` (no args)
# falls back to `all`.
# #############################################################################
LDS_ENABLE_PROXY=true
LDS_ENABLE_PHP=true
LDS_ENABLE_MYSQL=true
LDS_ENABLE_POSTGRES=false
LDS_ENABLE_MONGO=false
LDS_ENABLE_REDIS=false
LDS_ENABLE_MEMCACHED=false
LDS_ENABLE_KAFKA=false
LDS_ENABLE_PHPCACHEADMIN=false
LDS_ENABLE_DBGATE=true
LDS_ENABLE_SOKETI=false
LDS_ENABLE_CENTRIFUGO=false
LDS_ENABLE_MQTT=false
LDS_ENABLE_DRAWDB=false
LDS_ENABLE_HOP=false
LDS_ENABLE_SUPERSET=false
LDS_ENABLE_SEMGREP=false

# HTTPS overlay (opt-in feature, NOT a service profile). When true AND a
# proxy/php profile runs, `lds up` adds TLS to the edge proxy via
# docker-compose.https.yml and serves https://*.test. Mint the dev cert first:
#   lds certs        (uses mkcert if installed; else a self-signed openssl cert)
# Tunables (port / redirect behaviour) live in the Web block below.
LDS_ENABLE_HTTPS=false


# #############################################################################
# 3. BASE IMAGE VERSIONS  (built by ./lds.sh build-bases into lds/*)
# -----------------------------------------------------------------------------
# Defaults also live in scripts/build/build-bases.sh; export to override there.
# Bases now build FROM Docker Hardened Images (DHI). DHI_REGISTRY is the DHI
# namespace; the lds/* dev bases use the `-dev` DHI flavor (shell + toolchain),
# the DB services (block 5) use the plain runtime flavor. Each FROM tag's OS/
# flavor suffix (e.g. -debian13-dev, -alpine3.24-dev, -fpm-dev) lives in the
# matching base-images/*/Dockerfile; only the version number is set here.
# #############################################################################
DHI_REGISTRY=dhi.io
PHP_VERSION=8.4
GO_VERSION=1.26
RUST_VERSION=1.96
NODE_VERSION=26.3
JAVA_VERSION=25
PYTHON_VERSION=3.14


# #############################################################################
# 4. PROJECT PATHS  (where `lds new` scaffolds each technology)
# -----------------------------------------------------------------------------
# PHP_PROJECTS_PATH is special: it's ALSO the live mass-vhost mount for the php
# service — each <folder> under it is served at <folder>.test (docroot
# auto-detected: public/ > htdocs/ > root). Defaults to ./www (the example
# folder shipped with LDS); point it at your real projects dir, e.g.
# PHP_PROJECTS_PATH=D:/projects/PHP. The others are just scaffold destinations
# for `lds new <tech> <name>` — point each at wherever you keep that language's
# projects (e.g. ../../Go).
# #############################################################################
PHP_PROJECTS_PATH=./www
GO_PROJECTS_PATH=./projects/go
RUST_PROJECTS_PATH=./projects/rust
NODE_PROJECTS_PATH=./projects/node
PYTHON_PROJECTS_PATH=./projects/python
JAVA_PROJECTS_PATH=./projects/java
# Hop ETL projects — each folder = one Hop project (scaffold with lds new hop <name>).
# Registered automatically via hop-conf when the hop profile starts.
HOP_PROJECTS_PATH=./data/hop/projects
# Superset project data — SQLite metadata (dashboards, charts, datasets, connections).
# Bind-mounted to /app/superset_home in the container. Superset reads/writes
# directly to disk — no export/import needed. Use the UI at superset.test.
SUPERSET_PROJECTS_PATH=./data/superset
# only cron-shell (language cron jobs use their language path)
JOBS_PROJECTS_PATH=./projects/jobs


# #############################################################################
# 5. SERVICES  (per-service settings, most specific)
# #############################################################################

# --- MySQL (profile: mysql) ---
# DHI runtime flavor (dhi.io/mysql:${MYSQL_VERSION}); no -dev — DB images aren't modified.
MYSQL_VERSION=8.4-debian13
MYSQL_HOST_PORT=4400
MYSQL_SERVER_ID=1
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app

# --- PostgreSQL (profile: postgres) ---
POSTGRES_VERSION=18.4-alpine3.24
POSTGRES_HOST_PORT=4401
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# --- MongoDB (profile: mongo) ---
# DHI mongodb -dev flavor: runtime is mongod-only (no mongosh/shell); -dev adds
# the shell (keyfile gen) + mongosh (mongo-init users + healthcheck). Authenticated
# replica set (root + app users, like mysql/postgres); app connects as
# mongodb://app:app@mongo:27017/app?replicaSet=rs0.
MONGO_VERSION=8.3-debian13-dev
MONGO_HOST_PORT=4402
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=root
MONGO_USER=app
MONGO_PASSWORD=app
MONGO_DATABASE=app

# --- Redis (profile: redis) ---
REDIS_VERSION=8.8-alpine3.24
REDIS_HOST_PORT=4403

# --- Memcached (profile: memcached) ---
MEMCACHED_VERSION=1.6-debian13
MEMCACHED_HOST_PORT=4404
MEMCACHED_MEMORY=64

# --- Web: PHP + nginx + proxy + dns (profiles: php, proxy) ---
# Devilbox-style multi-project hosting. PHP_PROJECTS_PATH (the mass-vhost mount)
# lives in the PROJECT PATHS block above; the php service uses lds/php:${PHP_VERSION}.
NGINX_VERSION=1.27-alpine
# Host port for the edge proxy (nginx-proxy). Keep 80 for clean URLs
# (http://myapp.test). Change only if port 80 is taken — then visit
# http://myapp.test:<port>. The proxy routes <name>.test to any container with
# VIRTUAL_HOST set (Go/Rust/Java/Node apps); PHP folders are the catch-all.
WEB_HOST_PORT=80
# HTTPS: host port for the proxy's TLS listener (used only when LDS_ENABLE_HTTPS=true).
WEB_HTTPS_PORT=443
# noredirect = serve both http and https; set to `redirect` to force http -> https.
HTTPS_METHOD=noredirect
# dnsmasq publishes DNS on this host port. Resolves *.test -> 127.0.0.1.
DNS_HOST_PORT=53
# NOTE: projects are served at the .test TLD. To change it, edit
# configs/nginx/default.conf and configs/dns/dnsmasq.conf together.

# --- Kafka / KRaft (profile: kafka) ---
# DHI kafka (${DHI_REGISTRY}/kafka). Controller+broker config is in
# configs/kafka/{controller,broker}.properties (DHI ignores KAFKA_* env).
KAFKA_VERSION=4.3-debian13
# Must be a valid base64 22-char KRaft cluster id; shared by controller+broker.
# Generate a new one with:
#   docker run --rm dhi.io/kafka:4.3-debian13 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_HOST_PORT=4410
KAFKA_AUTO_CREATE_TOPICS=true
# Comma-separated topics to auto-create:  name:partitions:replication
KAFKA_TOPICS=demo.events:1:1,demo.audit:3:1

# Schema Registry — Apicurio Registry (Apache 2.0), replaces Confluent's
# cp-schema-registry. Confluent-compatible API exposed at /apis/ccompat/v7.
APICURIO_VERSION=2.6.13.Final
SCHEMA_REGISTRY_HOST_PORT=4411

# Kafka Connect powered by Debezium (MySQL + Postgres CDC connectors built in)
DEBEZIUM_VERSION=3.0
CONNECT_HOST_PORT=4413
CONNECT_GROUP_ID=connect-cluster
CONNECT_CONFIG_TOPIC=_connect_configs
CONNECT_OFFSET_TOPIC=_connect_offsets
CONNECT_STATUS_TOPIC=_connect_status

# Generic Kafka Connect (vanilla apache/kafka image — same runtime, NO bundled
# connectors). Drop plugin JARs into configs/kafka/connect-generic/plugins/.
# Config (group id, state topics, converters) lives in that folder's
# connect-distributed.properties.
CONNECT_GENERIC_HOST_PORT=4412

# Kafka UI (kafbat — maintained fork of provectus kafka-ui). Pinned to a release
# tag (not `latest`) for reproducible builds; bump as new versions ship.
KAFKA_UI_IMAGE=ghcr.io/kafbat/kafka-ui
KAFKA_UI_VERSION=v1.5.0
KAFKA_UI_HOST_PORT=4420

# --- Realtime / pub-sub brokers (profiles: soketi | centrifugo | mqtt) ---
# OFF by default (toggles above). Each is STATELESS (no data volume → no disk
# creep) and capped via mem/cpu below. Pick the broker whose CLIENT protocol
# matches your app — they are not interchangeable client-side.

# Soketi — Pusher-protocol WS server. Laravel Reverb/Echo + pusher-js compatible.
# In your Laravel app: BROADCAST_DRIVER=pusher, PUSHER_HOST=soketi, PUSHER_PORT=6001,
# PUSHER_APP_ID/KEY/SECRET = the values below. Echo connects with the same key.
SOKETI_VERSION=1.6-16-alpine
SOKETI_HOST_PORT=4430
SOKETI_HOST=ws.test
SOKETI_DEBUG=0
SOKETI_APP_ID=app-id
SOKETI_APP_KEY=app-key
SOKETI_APP_SECRET=app-secret
SOKETI_MEM_LIMIT=256m
SOKETI_CPUS=0.50

# Centrifugo — raw WebSocket channels + built-in admin UI (centrifugo.test / :4431).
# Clients use the Centrifuge JS SDK (not Echo). Runs in dev "insecure" mode so you
# can publish/subscribe without JWTs (flags set in docker-compose.yml).
CENTRIFUGO_VERSION=v5
CENTRIFUGO_HOST_PORT=4431
CENTRIFUGO_HOST=centrifugo.test
CENTRIFUGO_ALLOWED_ORIGINS=*
CENTRIFUGO_API_KEY=api-key
CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=token-secret
CENTRIFUGO_ADMIN_PASSWORD=admin
CENTRIFUGO_ADMIN_SECRET=admin-secret
CENTRIFUGO_MEM_LIMIT=256m
CENTRIFUGO_CPUS=0.50

# MQTT — Eclipse Mosquitto broker + MQTTX Web client (profile: mqtt). Replaces
# EMQX: lightweight, anonymous, and the web UI (mqtt.test) needs NO login. Clients
# use an MQTT library (MQTT.js / Paho); browser clients use the WS port (4433).
# MQTT<->Kafka is done via the generic Kafka Connect worker + Stream Reactor MQTT
# connector (not the broker) — see docs/en/15-data-tools.md.
MOSQUITTO_VERSION=2.0.22
# native MQTT (in-network: mosquitto:1883)
MQTT_HOST_PORT=4432
# MQTT over WebSocket (point MQTTX here: localhost:4433)
MQTT_WS_HOST_PORT=4433
MOSQUITTO_MEM_LIMIT=128m
# MQTTX Web — no-login browser MQTT client.
MQTTX_VERSION=v1.13.0
MQTT_HOST=mqtt.test
MQTTX_HOST_PORT=4434
MQTTX_MEM_LIMIT=128m

# --- Admin tools (profiles: phpcacheadmin | dbgate) ---
# Independent web UIs, each on its own profile. Reachable at <host>.test (via
# proxy) or http://localhost:<port>.
# phpCacheAdmin (Redis + Memcached); DBGate (MySQL + Postgres, pre-connected).
PHPCACHEADMIN_VERSION=2.5.1
CACHE_ADMIN_HOST=cache.test
CACHE_ADMIN_HOST_PORT=4421
DBGATE_VERSION=7.2.0
DB_ADMIN_HOST=db.test
DB_ADMIN_HOST_PORT=4422

# --- DrawDB (profile: drawdb) — browser DB schema designer / ER diagrams ---
# Upstream image (not on DHI); static SPA, diagrams persist in your browser.
DRAWDB_IMAGE=ghcr.io/drawdb-io/drawdb
DRAWDB_VERSION=v1.7.0
DRAWDB_HOST=drawdb.test
DRAWDB_HOST_PORT=4423

# --- Data warehouse tooling (profiles: hop | superset) ---
# Apache Hop Web = browser ETL/DW pipeline designer (upstream image). No login;
# served under /ui (the app auto-redirects / -> /ui). Connect it to postgres/mysql.
# NOTE: use apache/hop-web (the designer), NOT apache/hop (headless hop-server).
HOP_IMAGE=apache/hop-web
HOP_VERSION=2.18.1
# MySQL Connector/J jar mounted into Hop's shared jdbc folder (not bundled — GPL).
# Download it once into configs/hop/jdbc-drivers/ (see the README there).
HOP_MYSQL_DRIVER=mysql-connector-j-9.7.0.jar
HOP_HOST=hop.test
HOP_HOST_PORT=4424
# Where Hop projects live inside the container (mounted from HOP_PROJECTS_PATH).
# hop-conf registers each subfolder as a project in hop-config.json on up.
HOP_PROJECTS_CONTAINER_PATH=/usr/local/tomcat/projects

# Apache Superset = BI dashboards & reporting. Docker Hardened Image
# (${DHI_REGISTRY}/superset), non-dev runtime variant (nonroot, no shell) — the
# self-init runs via the image's venv python. Self-inits on first start; admin
# login below; metadata in a local SQLite volume. Add the stack DBs as data sources.
SUPERSET_VERSION=6.1-debian13
SUPERSET_HOST=superset.test
SUPERSET_HOST_PORT=4425
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=admin
SUPERSET_SECRET_KEY=lds-dev-secret-change-me

# --- Semgrep (profile: semgrep) — SAST scanner + lightweight SARIF viewer ---
# `lds tools semgrep [path]` runs the scan (upstream semgrep/semgrep image) and
# writes configs/semgrep/reports/report.sarif; the `semgrep` profile serves a
# self-contained viewer at semgrep.test. No DB.
# SEMGREP_RULES: ruleset to scan with. Use a registry pack (p/default, p/php,
# p/security-audit, p/ci), a rules URL, or a local YAML — these run with telemetry
# OFF. `auto` is also valid but REQUIRES metrics on (it phones home to pick rules),
# and that end-of-run upload can hang on slow/offline links.
SEMGREP_IMAGE=semgrep/semgrep
SEMGREP_VERSION=1.167.0
SEMGREP_RULES=p/default
SEMGREP_HOST=semgrep.test
SEMGREP_HOST_PORT=4426
